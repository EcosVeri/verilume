APP_TITLE=Verilume
APP_ICON=📚🔎
APP_PASSWORD=
MAX_CHAT_MESSAGES=30
SHOW_LOCAL_SOURCES=true
ANSWER_STYLE=Standard

DOCS_DIR=~/.verilume/documents
CHROMA_DIR=~/.verilume/chroma_db
COLLECTION_NAME=verilume_docs

EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DEVICE=cpu

CHUNK_SIZE=1000
CHUNK_OVERLAP=120
RESET_DB=false
MAX_WORKERS=8
BATCH_SIZE=128
MANIFEST_PATH=~/.verilume/ingestion_manifest.json

HF_TOKEN=
HF_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_PROVIDER=auto
HF_MAX_NEW_TOKENS=700
HF_TEMPERATURE=0.1
HF_TIMEOUT_SECONDS=90

TAVILY_API_KEY=
WEB_SEARCH_PROVIDER=tavily
BRAVE_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=
BING_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
CUSTOM_WEB_SEARCH_PROVIDER=
CUSTOM_WEB_SEARCH_API_KEY=
CUSTOM_WEB_SEARCH_ENDPOINT=
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=20

RETRIEVER_K=5
MAX_HISTORY_TURNS=6
ENABLE_QUERY_REWRITE=true
RETRIEVAL_SCORE_THRESHOLD=0.35
