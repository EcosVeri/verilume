APP_TITLE=Verilume
APP_ICON=📚🔎
APP_PASSWORD=
MAX_CHAT_MESSAGES=30
SHOW_LOCAL_SOURCES=true
ANSWER_STYLE=Standard

DOCS_DIR=~/.verilume/documents
CHROMA_DIR=~/.verilume/chroma_db
COLLECTION_NAME=verilume_docs
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_PATH=~/.verilume/semantic_cache.json
SEMANTIC_CACHE_STABLE_TTL_SECONDS=604800
SEMANTIC_CACHE_CURRENT_TTL_SECONDS=3600
SEMANTIC_CACHE_ENTITY_TTL_SECONDS=604800
SEMANTIC_CACHE_LOCAL_TTL_SECONDS=0
TABLE_STORE_DIR=~/.verilume/tables
KNOWLEDGE_GRAPH_PATH=~/.verilume/knowledge_graph.sqlite
ENABLE_GRAPHRAG=true

EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DEVICE=cpu
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_DIR=~/.verilume/embedding_cache

CHUNK_SIZE=1000
CHUNK_OVERLAP=120
CHUNK_STRATEGY=semantic
RESET_DB=false
MAX_WORKERS=8
BATCH_SIZE=128
MANIFEST_PATH=~/.verilume/ingestion_manifest.json
PROCESS_PARSE_DOCUMENTS=true
METADATA_ABSTRACT_LIMIT=900
METADATA_KEYWORDS_LIMIT=400

HF_TOKEN=
HF_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_PROVIDER=auto
HF_MAX_NEW_TOKENS=700
HF_TEMPERATURE=0.1
HF_TIMEOUT_SECONDS=90

TAVILY_API_KEY=
WEB_SEARCH_PROVIDER=tavily
BRAVE_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=
BING_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
CUSTOM_WEB_SEARCH_PROVIDER=
CUSTOM_WEB_SEARCH_API_KEY=
CUSTOM_WEB_SEARCH_ENDPOINT=
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=20
WEB_SEARCH_CACHE_TTL_SECONDS=600
WEB_SEARCH_MAX_WORKERS=3
ENABLE_AGGRESSIVE_WEB_FALLBACK=true
WEB_SEARCH_FALLBACK_MAX_RESULTS=12

RETRIEVER_K=5
MAX_HISTORY_TURNS=6
ENABLE_QUERY_REWRITE=true
QUERY_REWRITE_MIN_HISTORY=1
QUERY_REWRITE_SIMILARITY_THRESHOLD=0.92
RETRIEVAL_SCORE_THRESHOLD=0.35
RETRIEVAL_MODE=hybrid
RRF_CONSTANT=60
RRF_DENSE_WEIGHT=1.0
RRF_LEXICAL_WEIGHT=1.0
RRF_SEMANTIC_BOOST=0.25
RRF_SCORE_SCALE=28.0
ENABLE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_DEVICE=cpu
RERANKER_TOP_K=8
RERANK_SEMANTIC_WEIGHT=0.52
RERANK_LEXICAL_WEIGHT=0.48
RERANK_PHRASE_BONUS_FULL=0.28
RERANK_PHRASE_BONUS_PARTIAL=0.16
RERANK_MISMATCH_PENALTY=0.55
RERANK_MISMATCH_THRESHOLD=0.72
STRONG_LOCAL_SCORE_THRESHOLD=0.72
STRONG_LOCAL_MIN_SOURCES=1
EVIDENCE_AUTHORITY_BOOST=0.35
EVIDENCE_FRESHNESS_BOOST=0.1
EVIDENCE_FRESHNESS_DECAY_DAYS=365
CONFIDENCE_HIGH_THRESHOLD=0.8
CONFIDENCE_MEDIUM_THRESHOLD=0.6
ANSWER_VERIFICATION_MODE=heuristic
ANSWER_VERIFICATION_MIN_OVERLAP=0.18
